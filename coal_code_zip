}

export default function DashboardStats() {
  const [data, setData] = useState<DashboardData>({
    totalShippingAmount: 0,
    expressDeliveries: 0,
    totalPayments: 0,
    activeUsers: 0,
    coalPurchaseAmount: 0,
    subscriptionAmount: 0
  });
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    fetchDashboardData();
  }, []);

  const fetchDashboardData = async () => {
    try {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;

      // Fetch payments data
      const { data: payments, error: paymentsError } = await supabase
        .from('payments')
        .select('payment_type, amount, status')
        .eq('user_id', user.id)
        .eq('status', 'completed');

      if (paymentsError) throw paymentsError;

      // Fetch inventory data for shipping calculations
      const { data: inventory, error: inventoryError } = await supabase
        .from('inventory')
        .select('total_value, status')
        .eq('user_id', user.id);

      if (inventoryError) throw inventoryError;

      // Fetch locations for delivery count
      const { data: locations, error: locationsError } = await supabase
        .from('locations')
        .select('location_type')
        .eq('user_id', user.id);

      if (locationsError) throw locationsError;

      // Calculate stats
      const coalPurchases = payments?.filter(p => p.payment_type === 'coal_purchase') || [];
      const subscriptions = payments?.filter(p => p.payment_type === 'subscription') || [];
      
      const coalPurchaseAmount = coalPurchases.reduce((sum, p) => sum + p.amount, 0);
      const subscriptionAmount = subscriptions.reduce((sum, p) => sum + p.amount, 0);
      const totalInventoryValue = inventory?.reduce((sum, item) => sum + item.total_value, 0) || 0;
      const expressDeliveries = locations?.filter(loc => loc.location_type === 'delivery').length || 0;

      setData({
        totalShippingAmount: totalInventoryValue,
        expressDeliveries,
        totalPayments: payments?.length || 0,
        activeUsers: 1, // Current user
        coalPurchaseAmount,
        subscriptionAmount
      });
    } catch (error) {
      console.error('Error fetching dashboard data:', error);
    } finally {
      setIsLoading(false);
    }
  };

  const stats = [
    {
      title: "Total Shipping Value",
      value: `₹${data.totalShippingAmount.toFixed(2)}`,
      change: "+20.1%",
      trend: "up" as const,
      icon: DollarSign,
      period: "inventory value"
    },
    {
      title: "Delivery Locations",
      value: data.expressDeliveries.toString(),
      change: "+180.1%",
      trend: "up" as const, 
      icon: Truck,
      period: "active locations"
    },
    {
      title: "Total Payments",
      value: data.totalPayments.toString(),
      change: "+19%",
      trend: "up" as const,
      icon: DollarSign,
      period: `₹${(data.coalPurchaseAmount + data.subscriptionAmount).toFixed(2)} total`
    },
    {
      title: "Active Users",
      value: data.activeUsers.toString(),
      change: "+201",
      trend: "up" as const,
      icon: Users,
      period: "current session"
    },
  ];

  if (isLoading) {
    return (
      <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {[1, 2, 3, 4].map((i) => (
          <CardSkeletonLoader key={i} />
        ))}
      </div>
    );
  }

  return (
    <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat, index) => {
        const Icon = stat.icon;
        return (
          <Card key={index} className="animate-fade-up" style={{ animationDelay: `${index * 0.1}s`, animationFillMode: 'both' }}>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">
                {stat.title}
              </CardTitle>
              <Icon className="h-4 w-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold">{stat.value}</div>
              <p className="text-xs text-muted-foreground flex items-center">
                {stat.trend === "up" ? (
                  <ArrowUp className="mr-1 h-3 w-3 text-green-500" />
                ) : (
                  <ArrowDown className="mr-1 h-3 w-3 text-red-500" />
                )}
                <span className={stat.trend === "up" ? "text-green-500" : "text-red-500"}>
                  {stat.change}
                </span>
                <span className="ml-1">{stat.period}</span>
