interface InventoryItem {
  id: string;
  item_name: string;
  item_type: string;
  quantity: number;
  unit_price: number;
  total_value: number;
  location: string;
  description: string;
  status: string;
  created_at: string;
}

const InventoryManagement = () => {
  const [items, setItems] = useState<InventoryItem[]>([]);
  const [isAddDialogOpen, setIsAddDialogOpen] = useState(false);
  const [isEditDialogOpen, setIsEditDialogOpen] = useState(false);
  const [editingItem, setEditingItem] = useState<InventoryItem | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [isFetchingData, setIsFetchingData] = useState(true);
  const [formData, setFormData] = useState({
    item_name: '',
    item_type: 'coal',
    quantity: '',
    unit_price: '',
    location: '',
    description: '',
    status: 'active',
    phone_number: ''
  });
  const [editFormData, setEditFormData] = useState({
    item_name: '',
    item_type: 'coal',
    quantity: '',
    unit_price: '',
    location: '',
    description: '',
    status: 'active',
    phone_number: ''
  });
  const { toast } = useToast();

  // Search and filter states
  const [searchQuery, setSearchQuery] = useState('');
  const [filterType, setFilterType] = useState<string>('all');
  const [filterStatus, setFilterStatus] = useState<string>('all');

  // Filtered items based on search and filters
  const filteredItems = useMemo(() => {
    return items.filter(item => {
      const matchesSearch = item.item_name.toLowerCase().includes(searchQuery.toLowerCase()) ||
        item.description?.toLowerCase().includes(searchQuery.toLowerCase()) ||
        item.location?.toLowerCase().includes(searchQuery.toLowerCase());
      
      const matchesType = filterType === 'all' || item.item_type === filterType;
      const matchesStatus = filterStatus === 'all' || item.status === filterStatus;
      
      return matchesSearch && matchesType && matchesStatus;
    });
  }, [items, searchQuery, filterType, filterStatus]);

  const clearFilters = () => {
    setSearchQuery('');
    setFilterType('all');
    setFilterStatus('all');
  };

  useEffect(() => {
    fetchInventoryItems();
  }, []);

  const fetchInventoryItems = async () => {
    try {
      setIsFetchingData(true);
      const { data, error } = await supabase
        .from('inventory')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) throw error;
      setItems(data || []);
    } catch (error) {
      console.error('Error fetching inventory:', error);
      toast({
        title: "Error",
        description: "Failed to fetch inventory items",
        variant: "destructive",
      });
    } finally {
      setIsFetchingData(false);
    }
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    
    // Validate email and phone number format
    const { data: { user } } = await supabase.auth.getUser();
    if (!user?.email) {
      toast({
        title: "Error",
        description: "User email not found. Please log in again.",
        variant: "destructive",
      });
      return;
    }
    
    // Validate phone number format (E.164)
    const phoneRegex = /^\+\d{1,15}$/;
    if (formData.phone_number && !phoneRegex.test(formData.phone_number)) {
      toast({
        title: "Invalid Phone Number",
        description: "Please enter phone number in format: +[country code][number] (e.g., +916362298020)",
        variant: "destructive",
      });
      return;
    }
    
    setIsLoading(true);

    try {
      const { error } = await supabase
        .from('inventory')
        .insert({
          user_id: user.id,
          item_name: formData.item_name,
          item_type: formData.item_type,
          quantity: parseFloat(formData.quantity),
          unit_price: parseFloat(formData.unit_price),
          location: formData.location,
          description: formData.description,
          status: formData.status
        });

      if (error) throw error;

      // Send inventory management notification with email and SMS
      const notificationPayload = {
        type: 'inventory_management',
        userEmail: user.email,
        userName: user.user_metadata?.full_name || user.email,
        userPhone: formData.phone_number || undefined,
        action: 'added',
        details: {
          item_name: formData.item_name,
          item_type: formData.item_type,
          quantity: parseFloat(formData.quantity),
          unit_price: parseFloat(formData.unit_price),
          total_value: parseFloat(formData.quantity) * parseFloat(formData.unit_price),
          location: formData.location,
          description: formData.description,
          status: formData.status,
          timestamp: new Date().toISOString()
        }
      };
      
      console.log('Sending inventory notification:', notificationPayload);
      
      const { data: notificationResponse, error: notificationError } = await supabase.functions.invoke('send-notification', {
        body: notificationPayload
      });
      
      if (notificationError) {
        console.error('Notification error:', notificationError);
      } else {
        console.log('Notification sent successfully:', notificationResponse);
      }

      toast({
        title: "Success",
        description: formData.phone_number 
          ? "Inventory item added! Confirmation sent to your email and phone."
          : "Inventory item added! Confirmation sent to your email.",
      });

      setFormData({
        item_name: '',
        item_type: 'coal',
        quantity: '',
        unit_price: '',
        location: '',
        description: '',
        status: 'active',
        phone_number: ''
      });
      setIsAddDialogOpen(false);
      await fetchInventoryItems();
      setIsAddDialogOpen(false);
      fetchInventoryItems();
    } catch (error) {
      console.error('Error adding inventory item:', error);
      toast({
        title: "Error",
        description: "Failed to add inventory item",
        variant: "destructive",
      });
    } finally {
      setIsLoading(false);
    }
  };

  const handleEdit = (item: InventoryItem) => {
    setEditingItem(item);
    setEditFormData({
      item_name: item.item_name,
      item_type: item.item_type,
      quantity: item.quantity.toString(),
      unit_price: item.unit_price.toString(),
      location: item.location || '',
      description: item.description || '',
      status: item.status,
      phone_number: ''
    });
    setIsEditDialogOpen(true);
  };

  const handleUpdate = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!editingItem) return;

    const { data: { user } } = await supabase.auth.getUser();
    if (!user?.email) {
      toast({
        title: "Error",
        description: "User email not found. Please log in again.",
        variant: "destructive",
      });
      return;
    }

    // Validate phone number format (E.164)
    const phoneRegex = /^\+\d{1,15}$/;
    if (editFormData.phone_number && !phoneRegex.test(editFormData.phone_number)) {
      toast({
        title: "Invalid Phone Number",
        description: "Please enter phone number in format: +[country code][number] (e.g., +916362298020)",
        variant: "destructive",
      });
      return;
    }

    setIsLoading(true);

    try {
      const { error } = await supabase
        .from('inventory')
        .update({
          item_name: editFormData.item_name,
          item_type: editFormData.item_type,
          quantity: parseFloat(editFormData.quantity),
          unit_price: parseFloat(editFormData.unit_price),
          total_value: parseFloat(editFormData.quantity) * parseFloat(editFormData.unit_price),
          location: editFormData.location,
          description: editFormData.description,
          status: editFormData.status
        })
        .eq('id', editingItem.id);

      if (error) throw error;

      // Send inventory management notification with updated details
      const notificationPayload = {
        type: 'inventory_management',
        userEmail: user.email,
        userName: user.user_metadata?.full_name || user.email,
        userPhone: editFormData.phone_number || undefined,
        action: 'updated',
        details: {
          item_name: editFormData.item_name,
          item_type: editFormData.item_type,
          quantity: parseFloat(editFormData.quantity),
          unit_price: parseFloat(editFormData.unit_price),
          total_value: parseFloat(editFormData.quantity) * parseFloat(editFormData.unit_price),
          location: editFormData.location,
          description: editFormData.description,
          status: editFormData.status,
          timestamp: new Date().toISOString(),
          previous_item_name: editingItem.item_name,
          previous_quantity: editingItem.quantity,
          previous_unit_price: editingItem.unit_price
        }
      };

      console.log('Sending inventory update notification:', notificationPayload);

      const { data: notificationResponse, error: notificationError } = await supabase.functions.invoke('send-notification', {
        body: notificationPayload
      });

      if (notificationError) {
        console.error('Notification error:', notificationError);
      } else {
        console.log('Update notification sent successfully:', notificationResponse);
      }

      toast({
        title: "Success",
        description: editFormData.phone_number
          ? "Inventory item updated! Confirmation sent to your email and phone."
          : "Inventory item updated! Confirmation sent to your email.",
      });

      setIsEditDialogOpen(false);
      setEditingItem(null);
      await fetchInventoryItems();
    } catch (error) {
      console.error('Error updating inventory item:', error);
      toast({
        title: "Error",
        description: "Failed to update inventory item",
        variant: "destructive",
      });
    } finally {
      setIsLoading(false);
    }
  };

  const handleDelete = async (id: string) => {
    try {
      const itemToDelete = items.find(item => item.id === id);
      
      const { error } = await supabase
        .from('inventory')
        .delete()
        .eq('id', id);

      if (error) throw error;

      // Send notification
      const { data: { user: authUser } } = await supabase.auth.getUser();
      if (authUser?.email && itemToDelete) {
        await supabase.functions.invoke('send-notification', {
          body: {
            type: 'inventory',
            userEmail: authUser.email,
            userName: authUser.user_metadata?.full_name,
            action: 'deleted',
            details: {
              item_name: itemToDelete.item_name,
              quantity: itemToDelete.quantity
            }
          }
        });
      }

      toast({
        title: "Success",
        description: "Inventory item deleted successfully",
      });
      fetchInventoryItems();
    } catch (error) {
      console.error('Error deleting inventory item:', error);
      toast({
        title: "Error",
        description: "Failed to delete inventory item",
        variant: "destructive",
      });
    }
  };

  const totalValue = items.reduce((sum, item) => sum + item.total_value, 0);

  if (isFetchingData) {
    return (
      <div className="space-y-6">
        <div className="flex items-center justify-between">
          <div>
            <h2 className="text-3xl font-bold tracking-tight">Inventory Management</h2>
            <p className="text-muted-foreground">
              Manage your coal inventory and track stock levels
            </p>
          </div>
        </div>
        <TableSkeletonLoader rows={6} />
      </div>
    );
  }

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-3xl font-bold tracking-tight">Inventory Management</h2>
          <p className="text-muted-foreground">
