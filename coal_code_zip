// Helper to parse amount string (removes ₹ and commas)
const parseAmount = (amountStr: string): number => {
  if (!amountStr) return 0;
  const cleaned = amountStr.replace(/[₹,\s]/g, '');
  return parseFloat(cleaned) || 0;
};

const timeFilters = ["1 year", "6 month", "3 month", "1 month"];

export default function ShippingChart() {
  const [chartData, setChartData] = useState<Array<{month: string; orderCount: number; totalAmount: number}>>([]);
  const [selectedFilter, setSelectedFilter] = useState("6 month");
  const [isLoading, setIsLoading] = useState(true);

  const fetchOrderData = async () => {
    try {
      setIsLoading(true);
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;

      // Calculate date range based on selected filter
      const now = new Date();
      let startDate = new Date();
      
      switch (selectedFilter) {
        case "1 year":
          startDate.setFullYear(now.getFullYear() - 1);
          break;
        case "6 month":
          startDate.setMonth(now.getMonth() - 6);
          break;
        case "3 month":
          startDate.setMonth(now.getMonth() - 3);
          break;
        case "1 month":
          startDate.setMonth(now.getMonth() - 1);
          break;
      }

      // Fetch orders data for shipping amounts
      const { data: orders, error: ordersError } = await supabase
        .from('orders')
        .select('total_amount, order_date, status')
        .eq('user_id', user.id)
        .gte('order_date', startDate.toISOString())
        .order('order_date', { ascending: true });

      if (ordersError) throw ordersError;

      // Group data by month
      const monthlyData: Record<string, {month: string; orderCount: number; totalAmount: number}> = {};
      orders?.forEach(order => {
        const date = new Date(order.order_date);
        const monthKey = date.toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
        
        if (!monthlyData[monthKey]) {
          monthlyData[monthKey] = { month: monthKey, orderCount: 0, totalAmount: 0 };
        }
        
        monthlyData[monthKey].orderCount += 1;
        monthlyData[monthKey].totalAmount += parseAmount(order.total_amount);
      });

      const dataArray = Object.values(monthlyData);
      setChartData(dataArray.length > 0 ? dataArray : []);
    } catch (error) {
      console.error('Error fetching order data:', error);
      setChartData([]);
    } finally {
      setIsLoading(false);
    }
  };

  useEffect(() => {
    fetchOrderData();
  }, [selectedFilter]);

  // Real-time subscription for orders
  useEffect(() => {
    const channel = supabase
      .channel('orders-realtime')
      .on(
        'postgres_changes',
        {
          event: '*',
          schema: 'public',
          table: 'orders'
        },
        () => {
          fetchOrderData();
        }
      )
      .subscribe();

    return () => {
      supabase.removeChannel(channel);
    };
  }, [selectedFilter]);

  if (isLoading) {
    return <ChartSkeletonLoader />;
  }

  const totalShippingAmount = chartData.reduce((sum, item) => sum + item.totalAmount, 0);
  const averageAmount = chartData.length > 0 ? totalShippingAmount / chartData.length : 0;
  const totalOrders = chartData.reduce((sum, item) => sum + item.orderCount, 0);

  // Format currency for labels
  const formatCurrency = (value: number) => {
    if (value >= 1000) {
      return `₹${(value / 1000).toFixed(1)}K`;
    }
    return `₹${value.toFixed(0)}`;
  };

  return (
    <Card className="bg-card border-border animate-fade-up">
      <CardHeader>
        <div className="flex items-center justify-between flex-wrap gap-2">
          <div>
            <CardTitle className="text-xl font-semibold text-foreground">
              Total Shipping Amount
            </CardTitle>
            <div className="flex gap-4 mt-2">
              <div className="text-2xl font-bold text-primary">
                ₹{totalShippingAmount.toLocaleString('en-IN', { minimumFractionDigits: 2 })}
              </div>
              <div className="flex items-center gap-1 text-sm text-muted-foreground">
                <span className="font-medium text-foreground">{totalOrders}</span> orders
              </div>
            </div>
          </div>
          <div className="flex space-x-2">
            {timeFilters.map((filter) => (
              <Badge 
                key={filter} 
                variant={selectedFilter === filter ? "default" : "secondary"}
                className="cursor-pointer hover:bg-primary"
                onClick={() => setSelectedFilter(filter)}
              >
                {filter}
              </Badge>
            ))}
          </div>
        </div>
        <div className="text-sm text-muted-foreground">
          {selectedFilter} average: <span className="text-foreground font-medium">
            ₹{averageAmount.toLocaleString('en-IN', { minimumFractionDigits: 2 })}
          </span>
        </div>
      </CardHeader>
      <CardContent>
        {chartData.length === 0 ? (
          <div className="flex flex-col items-center justify-center h-[300px] text-muted-foreground">
            <svg className="w-16 h-16 mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5} d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <p className="text-center">No orders found for this period</p>
            <p className="text-xs mt-1">Create orders to see shipping data</p>
          </div>
        ) : (
          <>
            <ResponsiveContainer width="100%" height={320}>
              <LineChart data={chartData} margin={{ top: 20, right: 30, left: 20, bottom: 5 }}>
                <CartesianGrid strokeDasharray="3 3" stroke="hsl(var(--border))" opacity={0.5} />
                <XAxis 
                  dataKey="month" 
                  stroke="hsl(var(--muted-foreground))"
                  fontSize={12}
                  tickLine={false}
                />
                <YAxis 
                  yAxisId="left"
                  stroke="hsl(var(--muted-foreground))"
                  fontSize={12}
                  tickLine={false}
                  axisLine={false}
                  tickFormatter={(value) => formatCurrency(value)}
                />
                <YAxis 
                  yAxisId="right"
                  orientation="right"
                  stroke="hsl(var(--muted-foreground))"
                  fontSize={12}
                  tickLine={false}
                  axisLine={false}
                />
                <Tooltip 
                  contentStyle={{
                    backgroundColor: "hsl(var(--card))",
                    border: "1px solid hsl(var(--border))",
                    borderRadius: "8px",
                    color: "hsl(var(--foreground))",
                    boxShadow: "0 4px 12px rgba(0,0,0,0.15)"
                  }}
                  formatter={(value: number, name: string) => [
                    name === "Total Amount" ? `₹${value.toLocaleString('en-IN', { minimumFractionDigits: 2 })}` : value,
                    name
                  ]}
                  labelStyle={{ fontWeight: 'bold', marginBottom: '4px' }}
                />
                <Legend />
                <ReferenceLine 
                  y={averageAmount} 
                  yAxisId="left"
                  stroke="hsl(var(--primary))" 
                  strokeDasharray="5 5" 
                  label={{ value: `Avg: ${formatCurrency(averageAmount)}`, fill: 'hsl(var(--primary))', fontSize: 11 }}
                />
                <Line 
                  yAxisId="right"
                  type="monotone" 
                  dataKey="orderCount" 
                  stroke="hsl(var(--chart-blue))" 
                  strokeWidth={3}
                  name="Orders"
                  dot={{ fill: "hsl(var(--chart-blue))", strokeWidth: 2, r: 5 }}
                  activeDot={{ r: 8, strokeWidth: 2 }}
                >
                  <LabelList 
                    dataKey="orderCount" 
                    position="top" 
                    fill="hsl(var(--chart-blue))"
                    fontSize={11}
                    fontWeight="bold"
                  />
                </Line>
                <Line 
                  yAxisId="left"
                  type="monotone" 
                  dataKey="totalAmount" 
                  stroke="hsl(var(--success-green))" 
                  strokeWidth={3}
                  name="Total Amount"
                  dot={{ fill: "hsl(var(--success-green))", strokeWidth: 2, r: 5 }}
                  activeDot={{ r: 8, strokeWidth: 2 }}
                >
                  <LabelList 
                    dataKey="totalAmount" 
                    position="bottom" 
                    fill="hsl(var(--success-green))"
                    fontSize={10}
                    fontWeight="bold"
                    formatter={(value: number) => formatCurrency(value)}
                  />
                </Line>
              </LineChart>
            </ResponsiveContainer>
            <div className="flex items-center justify-between mt-4 pt-4 border-t border-border">
              <div className="flex items-center space-x-4">
                <div className="flex items-center space-x-2">
                  <div className="w-3 h-3 bg-chart-blue rounded-full"></div>
                  <span className="text-sm text-muted-foreground">Orders ({totalOrders})</span>
                </div>
                <div className="flex items-center space-x-2">
                  <div className="w-3 h-3 bg-success rounded-full"></div>
                  <span className="text-sm text-muted-foreground">Amount</span>
                </div>
              </div>
              <div className="text-sm font-medium text-foreground">
                Total: ₹{totalShippingAmount.toLocaleString('en-IN', { minimumFractionDigits: 2 })}
              </div>
            </div>
          </>
        )}
      </CardContent>
    </Card>
  );
}
