interface TransportLoaderProps {
  variant?: "truck" | "ship" | "train" | "all";
  className?: string;
  size?: "sm" | "md" | "lg";
}

export const TransportLoader = ({ 
  variant = "truck", 
  className,
  size = "md" 
}: TransportLoaderProps) => {
  const sizeClasses = {
    sm: "w-4 h-4",
    md: "w-6 h-6",
    lg: "w-8 h-8"
  };

  const iconSize = sizeClasses[size];

  if (variant === "all") {
    return (
      <div className={cn("flex items-center justify-center gap-8", className)}>
        <div className="relative w-24 h-8">
          <Truck className={cn(iconSize, "text-primary absolute animate-slide-forward")} 
            style={{ animation: 'slideForward 1.5s ease-in-out infinite' }} />
        </div>
        <div className="relative w-24 h-8">
          <Ship className={cn(iconSize, "text-info absolute animate-slide-forward")} 
            style={{ animation: 'slideForward 1.5s ease-in-out infinite 0.5s' }} />
        </div>
        <div className="relative w-24 h-8">
          <Train className={cn(iconSize, "text-warning absolute animate-slide-forward")} 
            style={{ animation: 'slideForward 1.5s ease-in-out infinite 1s' }} />
        </div>
      </div>
    );
  }

  const Icon = variant === "truck" ? Truck : variant === "ship" ? Ship : Train;
  const color = variant === "truck" ? "text-primary" : variant === "ship" ? "text-info" : "text-warning";

  return (
    <div className={cn("relative w-24 h-8", className)}>
      <Icon className={cn(iconSize, color, "absolute animate-slide-forward")} 
        style={{ animation: 'slideForward 1.5s ease-in-out infinite' }} />
    </div>
  );
};

