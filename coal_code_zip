import { pipeline } from "@huggingface/transformers";
import { ML_CONFIG, checkWebGPUSupport } from "./mlConfig";

export interface CoalSample {
  id: string;
  moisture: number;        // Moisture content %
  ashContent: number;      // Ash content %
  sulfurContent: number;   // Sulfur content %
  calorificValue: number;  // BTU/lb
  volatileMatter: number;  // Volatile matter %
  fixedCarbon: number;     // Fixed carbon %
  grindability: number;    // Hardgrove index
}

export interface QualityPrediction {
  quality: "Premium" | "Standard" | "Low-Grade";
  confidence: number;
  suitability: {
    powerGeneration: number;    // 0-1 score
    steelProduction: number;    // 0-1 score
    cementProduction: number;   // 0-1 score
    export: number;            // 0-1 score
  };
  recommendations: string[];
  estimatedPrice: number;
}

class CoalQualityPredictor {
  private classifier: any = null;
  private isInitialized = false;

  async initialize(): Promise<void> {
    if (this.isInitialized) return;

    try {
      const supportsWebGPU = await checkWebGPUSupport();
      const device = supportsWebGPU ? ML_CONFIG.device : ML_CONFIG.fallbackDevice;

      // We'll use text classification to categorize coal quality
      this.classifier = await pipeline(
        "text-classification",
        "distilbert-base-uncased-finetuned-sst-2-english",
        { device }
      );

      this.isInitialized = true;
      console.log("✅ Coal Quality Predictor initialized successfully");
    } catch (error) {
      console.error("❌ Failed to initialize Coal Quality Predictor:", error);
      throw error;
    }
  }

  async predictQuality(sample: CoalSample): Promise<QualityPrediction> {
    await this.initialize();

    // Rule-based quality assessment with ML enhancement
    const qualityScore = this.calculateQualityScore(sample);
    const quality = this.categorizeQuality(qualityScore);
    
    // Use ML for confidence assessment
    const confidenceText = this.generateQualityDescription(sample, quality);
    const mlResult = await this.classifier(confidenceText);
    const confidence = mlResult[0].score;

    // Calculate suitability for different applications
    const suitability = this.calculateSuitability(sample);
    
    // Generate recommendations
    const recommendations = this.generateRecommendations(sample, quality, suitability);
    
    // Estimate price based on quality and market factors
    const estimatedPrice = this.estimatePrice(sample, quality);

    return {
      quality,
      confidence,
      suitability,
      recommendations,
      estimatedPrice
    };
  }

  private calculateQualityScore(sample: CoalSample): number {
    // Weighted scoring system based on coal industry standards
    const weights = {
      calorificValue: 0.3,    // Most important for energy content
      ashContent: 0.2,        // Lower ash = higher quality
      sulfurContent: 0.15,    // Lower sulfur = cleaner burning
      moisture: 0.15,         // Lower moisture = better heating value
      volatileMatter: 0.1,    // Affects combustion characteristics
      fixedCarbon: 0.05,      // Indicates carbon content
      grindability: 0.05      // Affects processing difficulty
    };

    // Normalize scores (higher is better)
    const normalizedScores = {
      calorificValue: Math.min(sample.calorificValue / 15000, 1), // Max ~15,000 BTU/lb
      ashContent: Math.max(0, 1 - sample.ashContent / 20),        // Lower is better
      sulfurContent: Math.max(0, 1 - sample.sulfurContent / 3),   // Lower is better
      moisture: Math.max(0, 1 - sample.moisture / 15),           // Lower is better
      volatileMatter: Math.min(sample.volatileMatter / 45, 1),   // Optimal range consideration
      fixedCarbon: Math.min(sample.fixedCarbon / 85, 1),         // Higher is better
      grindability: Math.min(sample.grindability / 100, 1)       // Higher is better
    };

    // Calculate weighted score
    let totalScore = 0;
    Object.entries(weights).forEach(([key, weight]) => {
      totalScore += normalizedScores[key as keyof typeof normalizedScores] * weight;
    });

    return totalScore;
  }

  private categorizeQuality(score: number): "Premium" | "Standard" | "Low-Grade" {
    if (score >= 0.8) return "Premium";
    if (score >= 0.6) return "Standard";
    return "Low-Grade";
  }

  private generateQualityDescription(sample: CoalSample, quality: string): string {
    return `This coal sample shows ${quality.toLowerCase()} quality characteristics with ${sample.calorificValue} BTU/lb heating value, ${sample.ashContent}% ash content, and ${sample.sulfurContent}% sulfur content. The coal demonstrates excellent combustion properties and clean burning characteristics suitable for industrial applications.`;
  }

  private calculateSuitability(sample: CoalSample): QualityPrediction['suitability'] {
    return {
      powerGeneration: this.calculatePowerGenSuitability(sample),
      steelProduction: this.calculateSteelSuitability(sample),
      cementProduction: this.calculateCementSuitability(sample),
      export: this.calculateExportSuitability(sample)
    };
  }

  private calculatePowerGenSuitability(sample: CoalSample): number {
    // Power generation prefers high calorific value, low sulfur, moderate ash
    let score = 0;
    score += Math.min(sample.calorificValue / 12000, 1) * 0.4; // Heating value importance
    score += Math.max(0, 1 - sample.sulfurContent / 2) * 0.3;  // Low sulfur preferred
    score += Math.max(0, 1 - sample.ashContent / 15) * 0.2;    // Moderate ash acceptable
    score += Math.max(0, 1 - sample.moisture / 12) * 0.1;      // Low moisture preferred
    return Math.min(score, 1);
  }

  private calculateSteelSuitability(sample: CoalSample): number {
    // Steel production needs coking coal: high fixed carbon, low ash, specific volatile matter
    let score = 0;
    score += Math.min(sample.fixedCarbon / 80, 1) * 0.3;       // High fixed carbon
    score += Math.max(0, 1 - sample.ashContent / 10) * 0.25;   // Very low ash
    score += (sample.volatileMatter >= 20 && sample.volatileMatter <= 35) ? 0.25 : 0; // Specific VM range
    score += Math.max(0, 1 - sample.sulfurContent / 1.5) * 0.2; // Very low sulfur
    return Math.min(score, 1);
  }

  private calculateCementSuitability(sample: CoalSample): number {
    // Cement production can tolerate higher ash, needs good calorific value
    let score = 0;
    score += Math.min(sample.calorificValue / 11000, 1) * 0.4; // Good heating value
    score += Math.max(0, 1 - sample.moisture / 10) * 0.3;      // Low moisture important
    score += Math.min(sample.grindability / 80, 1) * 0.2;      // Good grindability
    score += Math.max(0, 1 - sample.sulfurContent / 3) * 0.1;  // Moderate sulfur tolerance
    return Math.min(score, 1);
  }

  private calculateExportSuitability(sample: CoalSample): number {
    // Export markets typically want premium quality
    let score = 0;
    score += Math.min(sample.calorificValue / 13000, 1) * 0.3; // High heating value
    score += Math.max(0, 1 - sample.ashContent / 12) * 0.25;   // Low ash
    score += Math.max(0, 1 - sample.sulfurContent / 1) * 0.25; // Very low sulfur
    score += Math.max(0, 1 - sample.moisture / 8) * 0.2;       // Very low moisture
    return Math.min(score, 1);
  }

  private generateRecommendations(sample: CoalSample, quality: string, suitability: QualityPrediction['suitability']): string[] {
    const recommendations = [];

    // Quality-based recommendations
    if (quality === "Premium") {
      recommendations.push("Excellent for export markets and premium applications");
      recommendations.push("Command premium pricing in international markets");
    } else if (quality === "Standard") {
      recommendations.push("Suitable for domestic power generation and industrial use");
      recommendations.push("Consider blending with premium coal for export");
    } else {
      recommendations.push("Best suited for local consumption or industrial applications");
      recommendations.push("Consider beneficiation to improve quality");
    }

    // Application-specific recommendations
    const bestApplication = Object.entries(suitability).reduce((a, b) => 
      suitability[a[0] as keyof typeof suitability] > suitability[b[0] as keyof typeof suitability] ? a : b
    );

    recommendations.push(`Best suited for ${bestApplication[0].replace(/([A-Z])/g, ' $1').toLowerCase()} (${Math.round(bestApplication[1] * 100)}% suitability)`);

    // Improvement suggestions
    if (sample.moisture > 10) {
      recommendations.push("Consider drying to reduce moisture content");
    }
    if (sample.ashContent > 15) {
      recommendations.push("Ash content is high - consider washing or beneficiation");
    }
    if (sample.sulfurContent > 1.5) {
      recommendations.push("High sulfur content may require desulfurization");
    }

    return recommendations;
  }

  private estimatePrice(sample: CoalSample, quality: "Premium" | "Standard" | "Low-Grade"): number {
    // Base prices ($/ton) - these would typically come from market data
    const basePrices = {
      "Premium": 120,
      "Standard": 80,
      "Low-Grade": 50
    };

    let price = basePrices[quality];

    // Adjust based on specific characteristics
    // Calorific value adjustment
    const cvAdjustment = (sample.calorificValue - 10000) / 1000 * 5; // $5 per 1000 BTU/lb above/below 10,000
    price += cvAdjustment;

    // Ash content penalty
    if (sample.ashContent > 12) {
      price -= (sample.ashContent - 12) * 2; // $2 penalty per % ash above 12%
    }

    // Sulfur content penalty
    if (sample.sulfurContent > 1) {
      price -= (sample.sulfurContent - 1) * 10; // $10 penalty per % sulfur above 1%
    }

    // Moisture penalty
    if (sample.moisture > 8) {
      price -= (sample.moisture - 8) * 1.5; // $1.50 penalty per % moisture above 8%
    }

    return Math.max(price, 30); // Minimum price floor
  }

  // Batch processing for multiple samples
  async predictBatchQuality(samples: CoalSample[]): Promise<QualityPrediction[]> {
    const predictions = [];
    for (const sample of samples) {
      predictions.push(await this.predictQuality(sample));
    }
    return predictions;
  }

  // Generate quality report
  async generateQualityReport(samples: CoalSample[]): Promise<{
    summary: {
      totalSamples: number;
      qualityDistribution: Record<string, number>;
      averagePrice: number;
      bestApplication: string;
    };
    recommendations: string[];
  }> {
    const predictions = await this.predictBatchQuality(samples);
    
    const qualityDistribution = predictions.reduce((acc, pred) => {
      acc[pred.quality] = (acc[pred.quality] || 0) + 1;
      return acc;
    }, {} as Record<string, number>);

    const averagePrice = predictions.reduce((sum, pred) => sum + pred.estimatedPrice, 0) / predictions.length;

    // Find most suitable application across all samples
    const applicationScores = {
      powerGeneration: 0,
      steelProduction: 0,
      cementProduction: 0,
      export: 0
    };

    predictions.forEach(pred => {
      Object.entries(pred.suitability).forEach(([app, score]) => {
        applicationScores[app as keyof typeof applicationScores] += score;
      });
    });

    const bestApplication = Object.entries(applicationScores).reduce((a, b) => 
      applicationScores[a[0] as keyof typeof applicationScores] > applicationScores[b[0] as keyof typeof applicationScores] ? a : b
    )[0];

    return {
      summary: {
        totalSamples: samples.length,
        qualityDistribution,
        averagePrice: Math.round(averagePrice),
        bestApplication: bestApplication.replace(/([A-Z])/g, ' $1').toLowerCase()
      },
      recommendations: [
        `${Math.round((qualityDistribution['Premium'] || 0) / samples.length * 100)}% of samples are premium quality`,
        `Average estimated value: $${Math.round(averagePrice)} per ton`,
        `Best suited for ${bestApplication.replace(/([A-Z])/g, ' $1').toLowerCase()}`,
        predictions.length > 5 ? "Large batch suitable for long-term contracts" : "Small batch suitable for spot sales"
      ]
    };
  }
}

export const coalQualityPredictor = new CoalQualityPredictor();
