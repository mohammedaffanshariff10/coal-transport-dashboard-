                {item.label}
              </Button>
            ))}
          </nav>
        )}
        
        {isCollapsed && (
          <nav className="space-y-2">
            {menuItems.map((item) => (
              <Button
                key={item.id}
                variant={activeSection === item.id ? "default" : "ghost"}
                size="sm"
                className="w-full p-2"
                onClick={() => item.onClick ? item.onClick() : onSectionChange(item.id)}
                title={item.label}
              >
                <item.icon className="h-4 w-4" />
              </Button>
            ))}
          </nav>
        )}
      </div>
    </aside>
  );
};

