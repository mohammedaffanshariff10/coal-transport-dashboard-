                    </video>
                  </div>
                </div>
              </div>
              
              <div className="space-y-4">
                <TrackShipmentDialog open={trackShipmentOpen} onOpenChange={setTrackShipmentOpen} />
                <SchedulePickupDialog open={schedulePickupOpen} onOpenChange={setSchedulePickupOpen} />
                <AddLocationDialog open={addLocationOpen} onOpenChange={setAddLocationOpen} />
