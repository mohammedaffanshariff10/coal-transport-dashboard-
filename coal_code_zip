  const [isProcessing, setIsProcessing] = useState(false);
  const [processingStep, setProcessingStep] = useState(0);
  const [orderDetails, setOrderDetails] = useState<OrderDetails | null>(null);
  const [inventoryTotal, setInventoryTotal] = useState<number>(0);
  const [loadingInventory, setLoadingInventory] = useState(true);
  const [selectedMethod, setSelectedMethod] = useState<string>("google_pay");

  useEffect(() => {
    const getUserDataAndInventory = async () => {
      const { data: { user } } = await supabase.auth.getUser();
      if (user) {
        setUserEmail(user.email || "");
        setUserName(user.user_metadata?.full_name || user.email || "Valued Customer");
        
        // Fetch inventory total value
        const { data: inventoryData, error } = await supabase
          .from('inventory')
          .select('total_value, quantity, unit_price')
          .eq('user_id', user.id);
        
        if (!error && inventoryData) {
          const total = inventoryData.reduce((sum, item) => {
            const itemTotal = item.total_value || (item.quantity * item.unit_price);
            return sum + Number(itemTotal);
          }, 0);
          setInventoryTotal(total);
        }
      }
      setLoadingInventory(false);
    };
    getUserDataAndInventory();
  }, []);
  
  const generatePDFReceipt = (customerName: string, order: OrderDetails) => {
    const doc = new jsPDF();
    
    // Set up the document
    doc.setFontSize(20);
    doc.setFont("helvetica", "bold");
    doc.text("MFC Digital Platform", 105, 20, { align: "center" });
    
    doc.setFontSize(16);
    doc.text("Payment Receipt", 105, 30, { align: "center" });
    
    // Add a line
    doc.setLineWidth(0.5);
    doc.line(20, 35, 190, 35);
    
    // Customer details
    doc.setFontSize(12);
    doc.setFont("helvetica", "normal");
    doc.text(`Customer Name: ${customerName}`, 20, 50);
    doc.text(`Date: ${order.orderDate}`, 20, 60);
    
    // Order details
    doc.setFont("helvetica", "bold");
    doc.text("Order Details:", 20, 75);
    
    doc.setFont("helvetica", "normal");
    doc.text(`Order ID: ${order.orderId}`, 20, 85);
    doc.text(`Items: ${order.items}`, 20, 95);
    
    // Amount box
    doc.setFillColor(240, 240, 240);
    doc.rect(20, 105, 170, 20, "F");
    doc.setFont("helvetica", "bold");
    doc.setFontSize(14);
    doc.text(`Total Amount: ${order.totalAmount}`, 25, 118);
    
    // Footer
    doc.setFontSize(10);
    doc.setFont("helvetica", "normal");
    doc.text("Thank you for your business!", 105, 140, { align: "center" });
    doc.text("This is an automatically generated receipt.", 105, 150, { align: "center" });
    
    doc.setFont("helvetica", "bold");
    doc.text("MFC Team", 105, 165, { align: "center" });
    
    return doc;
  };

  const handleDownloadReceipt = () => {
    if (!orderDetails) return;
    
    const doc = generatePDFReceipt(userName, orderDetails);
    doc.save(`Receipt_${orderDetails.orderId}.pdf`);
    toast.success("Receipt downloaded successfully!");
  };
  
  const simulatePaymentProgress = useCallback(async () => {
    const delays = [800, 1200, 1000, 800]; // Realistic delays for each step
    
    for (let i = 1; i <= 4; i++) {
      await new Promise(resolve => setTimeout(resolve, delays[i - 1]));
      setProcessingStep(i);
    }
  }, []);
  
  const handleConfirmPayment = async () => {
    if (!userEmail) {
      toast.error("Please log in to complete payment");
      return;
    }

    setIsLoading(true);
    setIsProcessing(true);
    setProcessingStep(1);
    
    try {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) {
        toast.error("Please log in to complete payment");
        setIsProcessing(false);
        setProcessingStep(0);
        return;
      }

      // Start progress simulation
      const progressPromise = simulatePaymentProgress();

      const formattedAmount = `₹${inventoryTotal.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      
      const order: OrderDetails = {
        orderId: `ORD-${Date.now()}`,
        items: "Inventory Items - Coal Order",
        totalAmount: formattedAmount,
        orderDate: new Date().toLocaleDateString('en-IN', { 
          year: 'numeric', 
          month: 'long', 
          day: 'numeric' 
        })
      };

      setOrderDetails(order);

      const selectedMethodName = paymentMethods.find(m => m.id === selectedMethod)?.name || "UPI";

      // Save order to database
      const { data: orderData, error: orderError } = await supabase
        .from('orders')
        .insert({
          user_id: user.id,
          order_id: order.orderId,
          items: order.items,
          total_amount: order.totalAmount,
          customer_name: userName,
          customer_email: userEmail,
          payment_method: selectedMethodName,
          status: "confirmed"
        })
        .select()
        .single();

      if (orderError) {
        console.error("Error saving order:", orderError);
        toast.error("Failed to save order");
        return;
      }

      // Save payment record
      const { error: paymentError } = await supabase
        .from('payments')
        .insert({
          user_id: user.id,
          amount: inventoryTotal,
          currency: 'INR',
          payment_type: 'order',
          payment_method: selectedMethodName,
          status: 'completed',
          reference_id: orderData.id,
          transaction_id: order.orderId,
          metadata: {
            order_id: order.orderId,
            items: order.items
          }
        });

      if (paymentError) {
        console.error("Error saving payment:", paymentError);
      }

      // Send notification
      await supabase.functions.invoke('send-notification', {
        body: {
          type: 'payments',
          userEmail: userEmail,
          userName: userName,
          action: 'completed',
          details: {
            amount: order.totalAmount,
            orderId: order.orderId,
            items: order.items
          }
        }
      });

      // Wait for progress animation to complete
      await progressPromise;

      setIsSuccess(true);
      setIsProcessing(false);
      setProcessingStep(0);
      toast.success("Payment confirmed! Order saved successfully.");
      setTimeout(() => setIsSuccess(false), 5000);
    } catch (error) {
      console.error("Error processing payment:", error);
      toast.error("Failed to process payment");
      setIsProcessing(false);
      setProcessingStep(0);
    } finally {
      setIsLoading(false);
    }
  };

  const formattedDisplayAmount = `₹${inventoryTotal.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

  if (isSuccess) {
    return (
      <Card className="w-full max-w-md bg-card border-border text-center animate-scale-in mx-auto">
        <CardContent className="pt-12 pb-8 space-y-6">
          <div className="w-20 h-20 bg-gradient-to-br from-success to-info rounded-full mx-auto mb-6 flex items-center justify-center animate-pulse">
            <Check className="w-10 h-10 text-white" />
          </div>
          <div>
            <h2 className="text-2xl font-bold text-foreground mb-2">Payment Confirmed!</h2>
            <p className="text-muted-foreground">Your payment of {orderDetails?.totalAmount} has been processed successfully</p>
          </div>
          <Button
            onClick={handleDownloadReceipt}
            className="w-full bg-primary hover:bg-primary/90 text-primary-foreground"
          >
            <Download className="w-4 h-4 mr-2" />
            Download Receipt
          </Button>
        </CardContent>
      </Card>
    );
  }

  // Processing View
  if (isProcessing) {
    const selectedMethodName = paymentMethods.find(m => m.id === selectedMethod)?.name || "UPI";
    
    return (
      <Card className="w-full max-w-md bg-card border-border animate-scale-in mx-auto">
        <CardContent className="pt-8 pb-8 space-y-6">
          <div className="text-center">
            <h2 className="text-xl font-bold text-foreground mb-2">Processing Payment</h2>
            <p className="text-muted-foreground text-sm">Please wait while we process your payment</p>
          </div>
          
          <PaymentProgress currentStep={processingStep} paymentMethod={selectedMethodName} />
          
          <div className="bg-muted/30 rounded-xl p-4 text-center">
            <p className="text-sm text-muted-foreground mb-1">Amount</p>
            <p className="text-2xl font-bold text-foreground">{formattedDisplayAmount}</p>
          </div>
          
          <p className="text-xs text-center text-muted-foreground">
            Do not close this window or refresh the page
          </p>
        </CardContent>
      </Card>
    );
  }

  const selectedPaymentMethod = paymentMethods.find(m => m.id === selectedMethod) || paymentMethods[0];

  return (
    <Card className="w-full max-w-md bg-card border-border animate-scale-in mx-auto">
      <CardHeader className="text-center pb-4">
        <CardTitle className="text-xl font-bold text-foreground flex items-center justify-center gap-2">
          <Wallet className="w-5 h-5 text-primary" />
          Payment Method
        </CardTitle>
        <p className="text-sm text-muted-foreground mt-2">
          To confirm your delivery, make the payment
        </p>
      </CardHeader>
      
      <CardContent className="space-y-5">
        {/* Payment Method Selection */}
        <div className="space-y-2">
          <p className="text-sm font-medium text-foreground mb-3">Select Payment Method</p>
          {paymentMethods.map((method) => (
            <div
              key={method.id}
              onClick={() => setSelectedMethod(method.id)}
              className={`flex items-center gap-4 p-3 rounded-xl border-2 cursor-pointer transition-all ${
                selectedMethod === method.id
                  ? 'border-primary bg-primary/5'
                  : 'border-border hover:border-primary/50'
              }`}
            >
              <div className={`w-10 h-10 rounded-lg flex items-center justify-center ${
                selectedMethod === method.id
                  ? 'bg-primary text-primary-foreground'
                  : 'bg-muted text-muted-foreground'
              }`}>
                {method.icon}
              </div>
              <div className="flex-1">
                <h4 className="font-medium text-foreground">{method.name}</h4>
                <p className="text-xs text-muted-foreground">{method.description}</p>
              </div>
              {selectedMethod === method.id && (
                <Check className="w-5 h-5 text-primary" />
              )}
            </div>
          ))}
        </div>

        {/* Amount Display */}
        <div className="bg-muted/50 rounded-xl p-4 text-center">
          <p className="text-sm text-muted-foreground mb-1">Amount to pay (from Inventory)</p>
          {loadingInventory ? (
            <div className="flex items-center justify-center gap-2">
              <Loader2 className="w-5 h-5 animate-spin text-primary" />
              <span className="text-muted-foreground">Loading...</span>
            </div>
          ) : (
            <p className="text-2xl font-bold text-foreground">{formattedDisplayAmount}</p>
          )}
        </div>

        {inventoryTotal === 0 && !loadingInventory && (
          <p className="text-sm text-muted-foreground text-center">
            Add items to your inventory to generate a payment amount
          </p>
        )}

        {/* Confirm Payment Button */}
        <Button
          onClick={handleConfirmPayment}
          disabled={isLoading || !userEmail || inventoryTotal === 0 || loadingInventory}
          className="w-full h-14 bg-gradient-to-r from-success to-success/90 hover:from-success/90 hover:to-success text-white font-semibold rounded-xl transition-all duration-300 hover:scale-105 shadow-lg disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <div className="flex items-center justify-center gap-2">
            <CreditCard className="w-5 h-5" />
            <span className="text-base">
              {isLoading ? `Pay via ${selectedPaymentMethod.name}` : "Confirm Payment"}
            </span>
          </div>
        </Button>
      </CardContent>
    </Card>
  );
}
import { useState, useEffect } from "react";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Calendar } from "@/components/ui/calendar";
import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
import { History, Download, Calendar as CalendarIcon, IndianRupee, Filter, X } from "lucide-react";
import { supabase } from "@/integrations/supabase/client";
import { jsPDF } from "jspdf";
import { toast } from "sonner";
import { format } from "date-fns";
import { cn } from "@/lib/utils";

interface Payment {
  id: string;
  amount: number;
  currency: string;
  payment_method: string | null;
  status: string;
  transaction_id: string | null;
  created_at: string;
  metadata: {
    order_id?: string;
    items?: string;
  } | null;
}

export default function PaymentHistory() {
  const [payments, setPayments] = useState<Payment[]>([]);
  const [filteredPayments, setFilteredPayments] = useState<Payment[]>([]);
  const [loading, setLoading] = useState(true);
  const [userName, setUserName] = useState("");
  const [startDate, setStartDate] = useState<Date | undefined>();
  const [endDate, setEndDate] = useState<Date | undefined>();
  const [showFilters, setShowFilters] = useState(false);

  useEffect(() => {
    fetchPayments();
  }, []);

  useEffect(() => {
    filterPayments();
  }, [payments, startDate, endDate]);

  const filterPayments = () => {
    let filtered = [...payments];
    
    if (startDate) {
      filtered = filtered.filter(p => new Date(p.created_at) >= startDate);
    }
    if (endDate) {
      const endOfDay = new Date(endDate);
      endOfDay.setHours(23, 59, 59, 999);
      filtered = filtered.filter(p => new Date(p.created_at) <= endOfDay);
    }
    
    setFilteredPayments(filtered);
  };

  const clearFilters = () => {
    setStartDate(undefined);
    setEndDate(undefined);
  };

  const fetchPayments = async () => {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) {
      setLoading(false);
      return;
    }

    setUserName(user.user_metadata?.full_name || user.email || "Valued Customer");

    const { data, error } = await supabase
      .from('payments')
      .select('*')
      .eq('user_id', user.id)
      .order('created_at', { ascending: false });

    if (!error && data) {
      setPayments(data as Payment[]);
    }
    setLoading(false);
  };

  const downloadReceipt = (payment: Payment) => {
    const doc = new jsPDF();
    
    // Header
    doc.setFontSize(20);
    doc.setFont("helvetica", "bold");
    doc.text("MFC Digital Platform", 105, 20, { align: "center" });
    
    doc.setFontSize(16);
    doc.text("Payment Receipt", 105, 30, { align: "center" });
    
    doc.setLineWidth(0.5);
    doc.line(20, 35, 190, 35);
    
    // Details
    doc.setFontSize(12);
    doc.setFont("helvetica", "normal");
    doc.text(`Customer Name: ${userName}`, 20, 50);
    doc.text(`Date: ${new Date(payment.created_at).toLocaleDateString('en-IN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })}`, 20, 60);
    
    doc.setFont("helvetica", "bold");
    doc.text("Payment Details:", 20, 75);
    
    doc.setFont("helvetica", "normal");
    doc.text(`Transaction ID: ${payment.transaction_id || 'N/A'}`, 20, 85);
    doc.text(`Payment Method: ${payment.payment_method || 'N/A'}`, 20, 95);
    doc.text(`Status: ${payment.status}`, 20, 105);
    
    if (payment.metadata?.items) {
      doc.text(`Items: ${payment.metadata.items}`, 20, 115);
    }
    
    // Amount box
    doc.setFillColor(240, 240, 240);
    doc.rect(20, 125, 170, 20, "F");
    doc.setFont("helvetica", "bold");
    doc.setFontSize(14);
    doc.text(`Total Amount: ₹${payment.amount.toLocaleString('en-IN', { minimumFractionDigits: 2 })}`, 25, 138);
    
    // Footer
    doc.setFontSize(10);
    doc.setFont("helvetica", "normal");
    doc.text("Thank you for your business!", 105, 160, { align: "center" });
    doc.setFont("helvetica", "bold");
    doc.text("MFC Team", 105, 170, { align: "center" });
    
    doc.save(`Receipt_${payment.transaction_id || payment.id}.pdf`);
    toast.success("Receipt downloaded!");
  };

  const getStatusColor = (status: string) => {
    switch (status) {
      case 'completed': return 'bg-success/20 text-success border-success/30';
      case 'pending': return 'bg-warning/20 text-warning border-warning/30';
      case 'failed': return 'bg-destructive/20 text-destructive border-destructive/30';
      default: return 'bg-muted text-muted-foreground';
    }
  };

  if (loading) {
    return (
      <Card className="bg-card border-border">
        <CardContent className="p-6 text-center text-muted-foreground">
          Loading payment history...
        </CardContent>
      </Card>
    );
  }

  return (
    <Card className="bg-card border-border">
      <CardHeader className="pb-4">
        <div className="flex items-center justify-between">
          <CardTitle className="text-lg font-bold text-foreground flex items-center gap-2">
            <History className="w-5 h-5 text-primary" />
            Payment History
          </CardTitle>
          <Button
            variant="outline"
            size="sm"
            onClick={() => setShowFilters(!showFilters)}
            className="gap-2"
          >
            <Filter className="w-4 h-4" />
            Filter
          </Button>
        </div>
        
        {/* Date Range Filters */}
        {showFilters && (
          <div className="flex flex-wrap items-center gap-3 mt-4 p-3 bg-muted/30 rounded-lg">
            <div className="flex items-center gap-2">
              <span className="text-sm text-muted-foreground">From:</span>
              <Popover>
                <PopoverTrigger asChild>
                  <Button
                    variant="outline"
                    size="sm"
                    className={cn(
                      "w-[130px] justify-start text-left font-normal",
                      !startDate && "text-muted-foreground"
                    )}
                  >
                    <CalendarIcon className="w-4 h-4 mr-2" />
                    {startDate ? format(startDate, "dd MMM yyyy") : "Start date"}
                  </Button>
                </PopoverTrigger>
                <PopoverContent className="w-auto p-0" align="start">
                  <Calendar
                    mode="single"
                    selected={startDate}
                    onSelect={setStartDate}
                    initialFocus
                    className={cn("p-3 pointer-events-auto")}
                  />
                </PopoverContent>
              </Popover>
            </div>
            
            <div className="flex items-center gap-2">
              <span className="text-sm text-muted-foreground">To:</span>
              <Popover>
                <PopoverTrigger asChild>
                  <Button
                    variant="outline"
                    size="sm"
                    className={cn(
                      "w-[130px] justify-start text-left font-normal",
                      !endDate && "text-muted-foreground"
                    )}
                  >
                    <CalendarIcon className="w-4 h-4 mr-2" />
                    {endDate ? format(endDate, "dd MMM yyyy") : "End date"}
                  </Button>
                </PopoverTrigger>
                <PopoverContent className="w-auto p-0" align="start">
                  <Calendar
                    mode="single"
                    selected={endDate}
                    onSelect={setEndDate}
                    initialFocus
                    className={cn("p-3 pointer-events-auto")}
                  />
                </PopoverContent>
              </Popover>
            </div>
            
            {(startDate || endDate) && (
              <Button
                variant="ghost"
                size="sm"
                onClick={clearFilters}
                className="text-muted-foreground hover:text-foreground"
              >
                <X className="w-4 h-4 mr-1" />
                Clear
              </Button>
            )}
          </div>
        )}
        
        {(startDate || endDate) && (
          <p className="text-xs text-muted-foreground mt-2">
            Showing {filteredPayments.length} of {payments.length} payments
          </p>
        )}
      </CardHeader>
      
      <CardContent className="space-y-3">
        {filteredPayments.length === 0 ? (
          <p className="text-center text-muted-foreground py-4">
            {payments.length === 0 ? "No payment history found" : "No payments found for selected date range"}
          </p>
        ) : (
          <div className="max-h-80 overflow-y-auto space-y-3 pr-1">
            {filteredPayments.map((payment) => (
              <div
                key={payment.id}
                className="bg-muted/30 rounded-lg p-4 border border-border/50 hover:border-primary/30 transition-colors"
              >
                <div className="flex items-start justify-between gap-3">
                  <div className="flex-1 min-w-0">
                    <div className="flex items-center gap-2 mb-2">
                      <IndianRupee className="w-4 h-4 text-primary" />
                      <span className="font-semibold text-foreground">
                        ₹{payment.amount.toLocaleString('en-IN', { minimumFractionDigits: 2 })}
                      </span>
                      <Badge className={`text-xs ${getStatusColor(payment.status)}`}>
                        {payment.status}
                      </Badge>
                    </div>
                    
                    <div className="flex items-center gap-2 text-sm text-muted-foreground mb-1">
                      <CalendarIcon className="w-3.5 h-3.5" />
                      {new Date(payment.created_at).toLocaleDateString('en-IN', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                      })}
                    </div>
                    
                    {payment.payment_method && (
                      <p className="text-xs text-muted-foreground">
                        via {payment.payment_method}
                      </p>
                    )}
                  </div>
                  
                  <Button
                    size="sm"
                    variant="outline"
                    onClick={() => downloadReceipt(payment)}
                    className="shrink-0"
                  >
                    <Download className="w-3.5 h-3.5" />
                  </Button>
                </div>
              </div>
            ))}
          </div>
        )}
      </CardContent>
    </Card>
  );
}

import { Check, Clock, CreditCard, Shield, CheckCircle2 } from "lucide-react";
import { cn } from "@/lib/utils";

interface PaymentProgressProps {
  currentStep: number;
  paymentMethod: string;
}

const steps = [
  { id: 1, name: "Verifying", icon: Shield, description: "Validating details" },
  { id: 2, name: "Processing", icon: CreditCard, description: "Connecting to bank" },
  { id: 3, name: "Confirming", icon: Clock, description: "Awaiting confirmation" },
  { id: 4, name: "Completed", icon: CheckCircle2, description: "Payment successful" }
];

export default function PaymentProgress({ currentStep, paymentMethod }: PaymentProgressProps) {
  return (
    <div className="w-full py-4">
      <p className="text-sm text-center text-muted-foreground mb-4">
        Processing via {paymentMethod}
      </p>
      
      <div className="flex items-center justify-between relative">
        {/* Progress Line Background */}
        <div className="absolute top-5 left-0 right-0 h-1 bg-muted rounded-full mx-8" />
        
        {/* Progress Line Active */}
        <div 
          className="absolute top-5 left-0 h-1 bg-primary rounded-full mx-8 transition-all duration-500 ease-out"
          style={{ width: `calc(${((currentStep - 1) / (steps.length - 1)) * 100}% - 4rem)` }}
        />
        
        {steps.map((step, index) => {
          const isCompleted = currentStep > step.id;
          const isCurrent = currentStep === step.id;
          const Icon = step.icon;
          
          return (
            <div key={step.id} className="flex flex-col items-center z-10 flex-1">
              <div
                className={cn(
                  "w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300",
                  isCompleted && "bg-primary text-primary-foreground",
                  isCurrent && "bg-primary text-primary-foreground animate-pulse ring-4 ring-primary/30",
                  !isCompleted && !isCurrent && "bg-muted text-muted-foreground"
                )}
              >
                {isCompleted ? (
                  <Check className="w-5 h-5" />
                ) : (
                  <Icon className={cn("w-5 h-5", isCurrent && "animate-bounce")} />
                )}
              </div>
              <span className={cn(
                "text-xs mt-2 font-medium transition-colors",
                (isCompleted || isCurrent) ? "text-primary" : "text-muted-foreground"
              )}>
                {step.name}
              </span>
              <span className="text-[10px] text-muted-foreground hidden sm:block">
                {step.description}
              </span>
            </div>
          );
        })}
      </div>
    </div>
  );
}

import { useEffect, useRef } from "react";

interface FaceGuideOverlayProps {
  width: number;
  height: number;
}

export const FaceGuideOverlay = ({ width, height }: FaceGuideOverlayProps) => {
  const canvasRef = useRef<HTMLCanvasElement>(null);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Get computed primary color from CSS variable
    const computedStyle = getComputedStyle(document.documentElement);
    const primaryHsl = computedStyle.getPropertyValue('--primary').trim();
    const primaryColor = primaryHsl ? `hsl(${primaryHsl})` : '#3b82f6';

    canvas.width = width;
    canvas.height = height;

    // Clear canvas
    ctx.clearRect(0, 0, width, height);

    // Calculate oval dimensions for face guide
    const centerX = width / 2;
    const centerY = height / 2;
    const ovalWidth = Math.min(width, height) * 0.5;
    const ovalHeight = ovalWidth * 1.3; // Slightly taller for face shape

    // Draw semi-transparent overlay outside the oval
    ctx.fillStyle = 'rgba(0, 0, 0, 0.4)';
    ctx.fillRect(0, 0, width, height);

    // Clear the oval area
    ctx.globalCompositeOperation = 'destination-out';
    ctx.beginPath();
    ctx.ellipse(centerX, centerY, ovalWidth / 2, ovalHeight / 2, 0, 0, Math.PI * 2);
    ctx.fill();

    // Reset composite operation
    ctx.globalCompositeOperation = 'source-over';

    // Draw oval border with gradient
    const gradient = ctx.createLinearGradient(
      centerX - ovalWidth / 2,
      centerY - ovalHeight / 2,
      centerX + ovalWidth / 2,
      centerY + ovalHeight / 2
    );
    gradient.addColorStop(0, primaryColor);
    gradient.addColorStop(0.5, primaryColor);
    gradient.addColorStop(1, primaryColor);

    ctx.strokeStyle = gradient;
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.ellipse(centerX, centerY, ovalWidth / 2, ovalHeight / 2, 0, 0, Math.PI * 2);
    ctx.stroke();

    // Add animated dashed border effect
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.5)';
    ctx.lineWidth = 1;
    ctx.setLineDash([10, 10]);
    ctx.beginPath();
    ctx.ellipse(centerX, centerY, ovalWidth / 2 + 5, ovalHeight / 2 + 5, 0, 0, Math.PI * 2);
    ctx.stroke();
    ctx.setLineDash([]);

    // Draw corner markers for positioning
    const markerSize = 20;
    const markerOffset = 10;
    ctx.strokeStyle = primaryColor;
    ctx.lineWidth = 2;

    // Top-left corner
    ctx.beginPath();
    ctx.moveTo(centerX - ovalWidth / 2 - markerOffset, centerY - ovalHeight / 2 + markerSize);
    ctx.lineTo(centerX - ovalWidth / 2 - markerOffset, centerY - ovalHeight / 2 - markerOffset);
    ctx.lineTo(centerX - ovalWidth / 2 + markerSize, centerY - ovalHeight / 2 - markerOffset);
    ctx.stroke();

    // Top-right corner
    ctx.beginPath();
    ctx.moveTo(centerX + ovalWidth / 2 + markerOffset, centerY - ovalHeight / 2 + markerSize);
    ctx.lineTo(centerX + ovalWidth / 2 + markerOffset, centerY - ovalHeight / 2 - markerOffset);
    ctx.lineTo(centerX + ovalWidth / 2 - markerSize, centerY - ovalHeight / 2 - markerOffset);
    ctx.stroke();

    // Bottom-left corner
    ctx.beginPath();
    ctx.moveTo(centerX - ovalWidth / 2 - markerOffset, centerY + ovalHeight / 2 - markerSize);
    ctx.lineTo(centerX - ovalWidth / 2 - markerOffset, centerY + ovalHeight / 2 + markerOffset);
    ctx.lineTo(centerX - ovalWidth / 2 + markerSize, centerY + ovalHeight / 2 + markerOffset);
    ctx.stroke();

    // Bottom-right corner
    ctx.beginPath();
    ctx.moveTo(centerX + ovalWidth / 2 + markerOffset, centerY + ovalHeight / 2 - markerSize);
    ctx.lineTo(centerX + ovalWidth / 2 + markerOffset, centerY + ovalHeight / 2 + markerOffset);
    ctx.lineTo(centerX + ovalWidth / 2 - markerSize, centerY + ovalHeight / 2 + markerOffset);
    ctx.stroke();

    // Add helper text
    ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
    ctx.font = '12px system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('Position your face within the oval', centerX, height - 20);

  }, [width, height]);

  return (
    <canvas
      ref={canvasRef}
      className="absolute inset-0 pointer-events-none"
      style={{ width, height }}
    />
  );
};

import { useState, useRef, useEffect, useCallback } from "react";
import { Button } from "@/components/ui/button";
import { Slider } from "@/components/ui/slider";
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogDescription } from "@/components/ui/dialog";
import { ZoomIn, ZoomOut, RotateCw, Check, X } from "lucide-react";

interface ImageCropperProps {
  imageUrl: string | null;
  isOpen: boolean;
  onClose: () => void;
  onCropComplete: (croppedBlob: Blob) => void;
}

export const ImageCropper = ({ imageUrl, isOpen, onClose, onCropComplete }: ImageCropperProps) => {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const containerRef = useRef<HTMLDivElement>(null);
  const [image, setImage] = useState<HTMLImageElement | null>(null);
  const [scale, setScale] = useState(1);
  const [rotation, setRotation] = useState(0);
  const [position, setPosition] = useState({ x: 0, y: 0 });
  const [isDragging, setIsDragging] = useState(false);
  const [dragStart, setDragStart] = useState({ x: 0, y: 0 });

  const CROP_SIZE = 200;

  // Load image when URL changes
  useEffect(() => {
    if (!imageUrl) return;

    const img = new Image();
    img.crossOrigin = "anonymous";
    img.onload = () => {
      setImage(img);
      setScale(1);
      setRotation(0);
      setPosition({ x: 0, y: 0 });
    };
    img.src = imageUrl;
  }, [imageUrl]);

  // Draw image on canvas
  const drawImage = useCallback(() => {
    if (!canvasRef.current || !image) return;

    const canvas = canvasRef.current;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const containerWidth = 300;
    const containerHeight = 300;
    canvas.width = containerWidth;
    canvas.height = containerHeight;

    // Clear canvas
    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, 0, containerWidth, containerHeight);

    // Calculate scaled dimensions
    const aspectRatio = image.width / image.height;
    let drawWidth, drawHeight;
    
    if (aspectRatio > 1) {
      drawHeight = containerHeight * scale;
      drawWidth = drawHeight * aspectRatio;
    } else {
      drawWidth = containerWidth * scale;
      drawHeight = drawWidth / aspectRatio;
    }

    // Save context state
    ctx.save();

    // Move to center, apply rotation
    ctx.translate(containerWidth / 2 + position.x, containerHeight / 2 + position.y);
    ctx.rotate((rotation * Math.PI) / 180);

    // Draw image centered
    ctx.drawImage(
      image,
      -drawWidth / 2,
      -drawHeight / 2,
      drawWidth,
      drawHeight
    );

    // Restore context
    ctx.restore();

    // Draw crop overlay (darkened area outside circle)
    ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
    ctx.fillRect(0, 0, containerWidth, containerHeight);
    
    // Clear the circular crop area
    ctx.globalCompositeOperation = 'destination-out';
    ctx.beginPath();
    ctx.arc(containerWidth / 2, containerHeight / 2, CROP_SIZE / 2, 0, Math.PI * 2);
    ctx.fill();
    
    // Reset composite operation
    ctx.globalCompositeOperation = 'source-over';
    
    // Get computed primary color from CSS variable
    const computedStyle = getComputedStyle(document.documentElement);
    const primaryHsl = computedStyle.getPropertyValue('--primary').trim();
    const primaryColor = primaryHsl ? `hsl(${primaryHsl})` : '#3b82f6';
    
    // Draw crop circle border
    ctx.strokeStyle = primaryColor;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(containerWidth / 2, containerHeight / 2, CROP_SIZE / 2, 0, Math.PI * 2);
    ctx.stroke();

    // Draw guide lines
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';
    ctx.lineWidth = 1;
    ctx.setLineDash([5, 5]);
    
    // Horizontal line
    ctx.beginPath();
    ctx.moveTo(containerWidth / 2 - CROP_SIZE / 2, containerHeight / 2);
    ctx.lineTo(containerWidth / 2 + CROP_SIZE / 2, containerHeight / 2);
    ctx.stroke();
    
    // Vertical line
    ctx.beginPath();
    ctx.moveTo(containerWidth / 2, containerHeight / 2 - CROP_SIZE / 2);
    ctx.lineTo(containerWidth / 2, containerHeight / 2 + CROP_SIZE / 2);
    ctx.stroke();
    
    ctx.setLineDash([]);
  }, [image, scale, rotation, position]);

  useEffect(() => {
    drawImage();
  }, [drawImage]);

  // Mouse/Touch handlers for dragging
  const handleMouseDown = (e: React.MouseEvent | React.TouchEvent) => {
    setIsDragging(true);
    const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
    const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
    setDragStart({ x: clientX - position.x, y: clientY - position.y });
  };

  const handleMouseMove = (e: React.MouseEvent | React.TouchEvent) => {
    if (!isDragging) return;
    const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
    const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
    setPosition({
      x: clientX - dragStart.x,
      y: clientY - dragStart.y,
    });
  };

  const handleMouseUp = () => {
    setIsDragging(false);
  };

  const handleZoomChange = (value: number[]) => {
    setScale(value[0]);
  };

  const handleRotate = () => {
    setRotation((prev) => (prev + 90) % 360);
  };

  const handleCrop = () => {
    if (!image) return;

    // Create output canvas for cropped image
    const outputCanvas = document.createElement('canvas');
    const outputSize = 256; // Final avatar size
    outputCanvas.width = outputSize;
    outputCanvas.height = outputSize;
    const outputCtx = outputCanvas.getContext('2d');
    if (!outputCtx) return;

    // Calculate the crop area from the preview canvas
    const containerWidth = 300;
    const containerHeight = 300;

    // Create a temporary canvas to render the full transformed image
    const tempCanvas = document.createElement('canvas');
    tempCanvas.width = containerWidth;
    tempCanvas.height = containerHeight;
    const tempCtx = tempCanvas.getContext('2d');
    if (!tempCtx) return;

    // Calculate scaled dimensions
    const aspectRatio = image.width / image.height;
    let drawWidth, drawHeight;
    
    if (aspectRatio > 1) {
      drawHeight = containerHeight * scale;
      drawWidth = drawHeight * aspectRatio;
    } else {
      drawWidth = containerWidth * scale;
      drawHeight = drawWidth / aspectRatio;
    }

    // Apply transformations
    tempCtx.translate(containerWidth / 2 + position.x, containerHeight / 2 + position.y);
    tempCtx.rotate((rotation * Math.PI) / 180);
    tempCtx.drawImage(image, -drawWidth / 2, -drawHeight / 2, drawWidth, drawHeight);

    // Extract the circular crop area
    const cropX = (containerWidth - CROP_SIZE) / 2;
    const cropY = (containerHeight - CROP_SIZE) / 2;

    // Create circular mask
    outputCtx.beginPath();
    outputCtx.arc(outputSize / 2, outputSize / 2, outputSize / 2, 0, Math.PI * 2);
    outputCtx.closePath();
    outputCtx.clip();

    // Draw the cropped portion
    outputCtx.drawImage(
      tempCanvas,
      cropX, cropY, CROP_SIZE, CROP_SIZE,
      0, 0, outputSize, outputSize
    );

    // Convert to blob
    outputCanvas.toBlob(
      (blob) => {
        if (blob) {
          onCropComplete(blob);
        }
      },
      'image/png',
      1.0
    );
  };

  return (
    <Dialog open={isOpen} onOpenChange={(open) => !open && onClose()}>
      <DialogContent className="sm:max-w-md">
        <DialogHeader>
          <DialogTitle>Edit Photo</DialogTitle>
          <DialogDescription>
            Drag to position, zoom and rotate your photo
          </DialogDescription>
        </DialogHeader>

        <div className="space-y-4">
          {/* Canvas container */}
          <div
            ref={containerRef}
            className="relative mx-auto rounded-lg overflow-hidden cursor-move bg-muted"
            style={{ width: 300, height: 300 }}
            onMouseDown={handleMouseDown}
            onMouseMove={handleMouseMove}
            onMouseUp={handleMouseUp}
            onMouseLeave={handleMouseUp}
            onTouchStart={handleMouseDown}
            onTouchMove={handleMouseMove}
            onTouchEnd={handleMouseUp}
          >
            <canvas ref={canvasRef} className="w-full h-full" />
          </div>

          {/* Controls */}
          <div className="space-y-3">
            {/* Zoom control */}
            <div className="flex items-center gap-3">
              <ZoomOut className="h-4 w-4 text-muted-foreground" />
              <Slider
                value={[scale]}
                min={0.5}
                max={3}
                step={0.1}
                onValueChange={handleZoomChange}
                className="flex-1"
              />
              <ZoomIn className="h-4 w-4 text-muted-foreground" />
            </div>

            {/* Rotate button */}
            <div className="flex justify-center">
              <Button variant="outline" size="sm" onClick={handleRotate}>
                <RotateCw className="h-4 w-4 mr-2" />
                Rotate 90°
              </Button>
            </div>
          </div>

          {/* Action buttons */}
          <div className="flex justify-center gap-3">
            <Button variant="outline" onClick={onClose}>
              <X className="h-4 w-4 mr-2" />
              Cancel
            </Button>
            <Button onClick={handleCrop}>
              <Check className="h-4 w-4 mr-2" />
              Apply
            </Button>
          </div>
        </div>
      </DialogContent>
    </Dialog>
  );
};

import { useState, useEffect, useRef, useCallback } from "react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar";
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogDescription } from "@/components/ui/dialog";
import { useToast } from "@/hooks/use-toast";
import { supabase } from "@/integrations/supabase/client";
import { Camera, Upload, Loader2, Trash2, X, RefreshCw, Crop } from "lucide-react";
import { ImageCropper } from "./ImageCropper";
import { FaceGuideOverlay } from "./FaceGuideOverlay";

interface UserProfileProps {
  user: any;
}

export const UserProfile = ({ user }: UserProfileProps) => {
  const [fullName, setFullName] = useState("");
  const [avatarUrl, setAvatarUrl] = useState("");
  const [isLoading, setIsLoading] = useState(false);
  const [uploading, setUploading] = useState(false);
  const [isCameraOpen, setIsCameraOpen] = useState(false);
  const [cameraStream, setCameraStream] = useState<MediaStream | null>(null);
  const [capturedImage, setCapturedImage] = useState<string | null>(null);
  const [facingMode, setFacingMode] = useState<"user" | "environment">("user");
  const [isCropperOpen, setIsCropperOpen] = useState(false);
  const [imageForCrop, setImageForCrop] = useState<string | null>(null);
  
  const fileInputRef = useRef<HTMLInputElement>(null);
  const videoRef = useRef<HTMLVideoElement>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const videoContainerRef = useRef<HTMLDivElement>(null);
  const { toast } = useToast();

  const [videoSize, setVideoSize] = useState({ width: 320, height: 240 });

  useEffect(() => {
    if (user) {
      setFullName(user.user_metadata?.full_name || user.email || "");
      setAvatarUrl(user.user_metadata?.avatar_url || "");
      loadProfile();
    }
  }, [user]);

  // Cleanup camera stream on unmount
  useEffect(() => {
    return () => {
      if (cameraStream) {
        cameraStream.getTracks().forEach(track => track.stop());
      }
    };
  }, [cameraStream]);

  const loadProfile = async () => {
    try {
      const { data, error } = await supabase
        .from('profiles')
        .select('*')
        .eq('user_id', user.id)
        .single();

      if (error && error.code !== 'PGRST116') {
        console.error('Error loading profile:', error);
        return;
      }

      if (data) {
        setFullName(data.full_name || "");
        setAvatarUrl(data.avatar_url || "");
      }
    } catch (error) {
      console.error('Error:', error);
    }
  };

  const startCamera = useCallback(async () => {
    try {
      if (cameraStream) {
        cameraStream.getTracks().forEach(track => track.stop());
      }

      const stream = await navigator.mediaDevices.getUserMedia({
        video: { 
          facingMode: facingMode,
          width: { ideal: 640 },
          height: { ideal: 480 }
        },
        audio: false
      });

      setCameraStream(stream);
      
      if (videoRef.current) {
        videoRef.current.srcObject = stream;
        videoRef.current.onloadedmetadata = () => {
          const video = videoRef.current;
          if (video) {
            setVideoSize({
              width: video.videoWidth,
              height: video.videoHeight
            });
          }
        };
        await videoRef.current.play();
      }
    } catch (error: any) {
      console.error('Camera error:', error);
      toast({
        title: "Camera Error",
        description: error.message || "Could not access camera. Please check permissions.",
        variant: "destructive",
      });
      setIsCameraOpen(false);
    }
  }, [facingMode, cameraStream, toast]);

  const stopCamera = useCallback(() => {
    if (cameraStream) {
      cameraStream.getTracks().forEach(track => track.stop());
      setCameraStream(null);
    }
    setCapturedImage(null);
  }, [cameraStream]);

  const openCamera = async () => {
    setIsCameraOpen(true);
    setCapturedImage(null);
  };

  const closeCamera = () => {
    stopCamera();
    setIsCameraOpen(false);
    setCapturedImage(null);
  };

  const switchCamera = async () => {
    setFacingMode(prev => prev === "user" ? "environment" : "user");
  };

  useEffect(() => {
    if (isCameraOpen && !capturedImage) {
      startCamera();
    }
  }, [isCameraOpen, facingMode, capturedImage]);

  const capturePhoto = () => {
    if (videoRef.current && canvasRef.current) {
      const video = videoRef.current;
      const canvas = canvasRef.current;
      
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
      
      const ctx = canvas.getContext('2d');
      if (ctx) {
        if (facingMode === "user") {
          ctx.translate(canvas.width, 0);
          ctx.scale(-1, 1);
        }
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        
        const imageData = canvas.toDataURL('image/jpeg', 0.9);
        setCapturedImage(imageData);
        
        if (cameraStream) {
          cameraStream.getTracks().forEach(track => track.stop());
        }
      }
    }
  };

  const retakePhoto = () => {
    setCapturedImage(null);
    startCamera();
  };

  const usePhoto = async () => {
    if (!capturedImage) return;
    // Open cropper with captured image
    setImageForCrop(capturedImage);
    setIsCropperOpen(true);
    closeCamera();
  };

  const handleCropComplete = async (croppedBlob: Blob) => {
    try {
      setUploading(true);
      setIsCropperOpen(false);
      setImageForCrop(null);

      const file = new File([croppedBlob], `avatar-${Date.now()}.png`, { type: 'image/png' });
      await uploadAvatar(file);
    } catch (error: any) {
      toast({
        title: "Error",
        description: error.message,
        variant: "destructive",
      });
    } finally {
      setUploading(false);
    }
  };

  const uploadAvatar = async (file: File) => {
    try {
      setUploading(true);
      
      if (avatarUrl) {
        await removeAvatarSilent();
      }
      
      const fileExt = file.name.split('.').pop();
      const fileName = `${user.id}/${Math.random()}.${fileExt}`;

      const { error: uploadError } = await supabase.storage
        .from('avatars')
        .upload(fileName, file);

      if (uploadError) {
        throw uploadError;
      }

      const { data } = await supabase.storage
        .from('avatars')
        .createSignedUrl(fileName, 31536000);

      if (data?.signedUrl) {
        setAvatarUrl(data.signedUrl);
      }
      
      await logActivity('profile_update', 'Updated profile photo');
      
      toast({
        title: "Success",
        description: "Avatar uploaded successfully!",
      });
    } catch (error: any) {
      toast({
        title: "Error",
        description: error.message,
        variant: "destructive",
      });
    } finally {
      setUploading(false);
    }
  };

  const removeAvatarSilent = async () => {
    try {
      if (avatarUrl) {
        const urlParts = avatarUrl.split('/');
        const fileName = `${user.id}/${urlParts[urlParts.length - 1]}`;
        
        await supabase.storage
          .from('avatars')
          .remove([fileName]);
      }
    } catch (error) {
      console.error('Error removing avatar:', error);
    }
  };

  const removeAvatar = async () => {
    try {
      setUploading(true);
      
      if (avatarUrl) {
        const urlParts = avatarUrl.split('/');
        const fileName = `${user.id}/${urlParts[urlParts.length - 1]}`;
        
        await supabase.storage
          .from('avatars')
          .remove([fileName]);
      }
      
      setAvatarUrl("");
      
      await logActivity('profile_update', 'Removed profile photo');
      
      toast({
        title: "Success",
        description: "Avatar removed successfully!",
      });
    } catch (error: any) {
      toast({
        title: "Error",
        description: error.message,
        variant: "destructive",
      });
    } finally {
      setUploading(false);
    }
  };

  const handleFileUpload = (event: React.ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0];
    if (file) {
      if (file.size > 5 * 1024 * 1024) {
        toast({
          title: "Error",
          description: "File size must be less than 5MB",
          variant: "destructive",
        });
        return;
      }
      
      // Convert file to data URL and open cropper
      const reader = new FileReader();
      reader.onload = (e) => {
        const dataUrl = e.target?.result as string;
        setImageForCrop(dataUrl);
        setIsCropperOpen(true);
      };
      reader.readAsDataURL(file);
    }
    // Reset input
    if (event.target) {
      event.target.value = '';
    }
  };

  const logActivity = async (type: string, description: string, metadata = {}) => {
    try {
      await supabase
        .from('user_activities')
        .insert({
          user_id: user.id,
          activity_type: type,
          activity_description: description,
          metadata
        });
    } catch (error) {
      console.error('Error logging activity:', error);
    }
  };

  const handleSaveProfile = async () => {
    setIsLoading(true);
    try {
      const { error: profileError } = await supabase
        .from('profiles')
        .upsert({
          user_id: user.id,
          full_name: fullName,
          avatar_url: avatarUrl,
          email: user.email,
        }, {
          onConflict: 'user_id'
        });

      if (profileError) throw profileError;

      const { error: metadataError } = await supabase.auth.updateUser({
        data: {
          full_name: fullName,
          avatar_url: avatarUrl,
        }
      });

      if (metadataError) throw metadataError;

      await logActivity('profile_update', 'Updated profile information', {
        full_name: fullName,
        has_avatar: !!avatarUrl
      });

      toast({
        title: "Success",
        description: "Profile updated successfully!",
      });
    } catch (error: any) {
      toast({
        title: "Error",
        description: error.message,
        variant: "destructive",
      });
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <>
      <Card className="max-w-2xl mx-auto animate-fade-up">
        <CardHeader>
          <CardTitle>User Profile</CardTitle>
          <CardDescription>
            Update your profile information and photo
          </CardDescription>
        </CardHeader>
        <CardContent className="space-y-6">
          <div className="flex items-center space-x-4">
            <Avatar className="h-20 w-20">
              <AvatarImage src={avatarUrl} alt="User" />
              <AvatarFallback className="text-lg">
                {fullName?.charAt(0) || user?.email?.charAt(0) || 'U'}
              </AvatarFallback>
            </Avatar>
            <div className="space-y-2">
              <div className="flex flex-wrap gap-2">
                <Button
                  variant="outline"
                  size="sm"
                  onClick={() => fileInputRef.current?.click()}
                  disabled={uploading}
                >
                  <Upload className="h-4 w-4 mr-2" />
                  {uploading ? 'Uploading...' : 'Gallery'}
                </Button>
                <Button
                  variant="outline"
                  size="sm"
                  onClick={openCamera}
